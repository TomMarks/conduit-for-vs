<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

  <!--
    SPIKE-001: WebView2 inside a Remote UI tool window.

    Remote UI XAML runs in devenv.exe, so it can reference any assembly that devenv loads.
    VS 2026 loads Microsoft.Web.WebView2.Wpf.dll for Copilot; we piggyback on that.

    Source is a string→Uri binding — WPF's UriTypeConverter handles the conversion.
    The value is "about:blank" until ControlLoadedAsync starts the WebSocket bridge
    and pushes the real URL via INotifyPropertyChanged.

    Two-way comms go through ConduitWebSocketBridge (ws://localhost:<port>/ws) because
    Remote UI has no code-behind and CoreWebView2.WebMessageReceived is unreachable.
  -->

  <wv2:WebView2 Source="{Binding WebViewSource}" />

</DataTemplate>
