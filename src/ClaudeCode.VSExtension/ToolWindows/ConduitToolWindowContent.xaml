<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Phase 3.1: added sign-in banner (Row 1) that surfaces when ShowSignIn=True.
    BooleanToVisibilityConverter collapses/shows the banner; SignInCommand launches
    claude /login in an external console window via ClaudeAuthLauncher.
  -->

  <DataTemplate.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </DataTemplate.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ── Message list ───────────────────────────────────────────────── -->
    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Messages}" Margin="8,8,8,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <!--
              Each message is a full-width row.  The bubble floats left (assistant) or
              right (user) via HorizontalAlignment driven by a DataTrigger on IsUser.
              MaxWidth caps line length so wide windows don't produce unwieldy bubbles.
            -->
            <Grid Margin="0,0,0,8">
              <Border x:Name="Bubble"
                      HorizontalAlignment="Left"
                      MaxWidth="520"
                      Padding="10,7"
                      CornerRadius="6"
                      Background="#1c2128"
                      BorderBrush="#30363d"
                      BorderThickness="1">
                <StackPanel>
                  <TextBlock x:Name="MessageText"
                             Text="{Binding Text}"
                             TextWrapping="Wrap"
                             Foreground="#c9d1d9"
                             FontSize="13"
                             LineHeight="19" />
                  <!-- streaming cursor — hidden once IsStreaming=False -->
                  <TextBlock x:Name="Cursor"
                             Text="▌"
                             Foreground="#58a6ff"
                             FontSize="13"
                             Visibility="Collapsed" />
                </StackPanel>
              </Border>
            </Grid>

            <DataTemplate.Triggers>
              <!-- User message: right-aligned, distinct background -->
              <DataTrigger Binding="{Binding IsUser}" Value="True">
                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Bubble" Property="Background" Value="#0d419d" />
                <Setter TargetName="Bubble" Property="BorderBrush" Value="#1158c7" />
                <Setter TargetName="MessageText" Property="Foreground" Value="#e6edf3" />
              </DataTrigger>
              <!-- Streaming: show cursor -->
              <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                <Setter TargetName="Cursor" Property="Visibility" Value="Visible" />
              </DataTrigger>
            </DataTemplate.Triggers>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- ── Sign-in banner (hidden unless ShowSignIn=True) ────────────── -->
    <Border Grid.Row="1"
            Visibility="{Binding ShowSignIn, Converter={StaticResource BoolToVis}}"
            Background="#2d2208"
            BorderBrush="#9e6a03"
            BorderThickness="0,1,0,1"
            Padding="10,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Not signed in to Claude."
                   Foreground="#d29922"
                   FontSize="12"
                   VerticalAlignment="Center" />

        <Button Grid.Column="1"
                Command="{Binding SignInCommand}"
                Content="Sign In"
                Padding="12,5"
                FontSize="12"
                FontWeight="SemiBold"
                Background="#9e6a03"
                Foreground="#ffffff"
                BorderThickness="0" />
      </Grid>
    </Border>

    <!-- ── Status bar ─────────────────────────────────────────────────── -->
    <Border Grid.Row="2"
            Background="#161b22"
            BorderBrush="#30363d"
            BorderThickness="0,1,0,0"
            Padding="10,3">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#6e7681"
                 FontSize="11"
                 FontFamily="Consolas" />
    </Border>

    <!-- ── Input bar ──────────────────────────────────────────────────── -->
    <Border Grid.Row="3"
            Background="#0d1117"
            BorderBrush="#30363d"
            BorderThickness="0,1,0,0"
            Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Column="0"
                 Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="False"
                 VerticalContentAlignment="Center"
                 Padding="8,6"
                 FontSize="13"
                 Background="#161b22"
                 Foreground="#e6edf3"
                 BorderBrush="#30363d"
                 CaretBrush="#e6edf3"
                 Margin="0,0,6,0">
          <TextBox.InputBindings>
            <KeyBinding Key="Return" Command="{Binding SendCommand}" />
          </TextBox.InputBindings>
        </TextBox>

        <Button Grid.Column="1"
                Command="{Binding SendCommand}"
                IsEnabled="{Binding CanSend}"
                Padding="14,6"
                FontSize="13"
                FontWeight="SemiBold"
                Background="#238636"
                Foreground="#ffffff"
                BorderThickness="0"
                Content="Send" />
      </Grid>
    </Border>

  </Grid>

</DataTemplate>
