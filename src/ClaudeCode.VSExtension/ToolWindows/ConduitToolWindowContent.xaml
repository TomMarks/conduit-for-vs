<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

  <!--
    SPIKE-001: WebView2 inside a Remote UI tool window.
    See docs/spikes/SPIKE-001-webview2-in-remote-ui.md.
  -->

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />

      <!-- SPIKE-001 DIAGNOSTIC ROW — delete this RowDefinition + the Border below before Phase 1 ships -->
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <wv2:WebView2 Source="{Binding WebViewSource}" Grid.Row="0" />

    <!-- ═══════════════════════════════════════════════════════════════════
         SPIKE-001 DIAGNOSTIC BAR — remove this entire Border before Phase 1 ships.
         Purpose: proves the ViewModel and bridge are wiring up even if WebView2
         is blank.  If DiagnosticText shows the localhost URL, the bridge is live;
         paste that URL into a browser to verify the chat page loads.
         ═══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="8,4">
      <TextBlock Text="{Binding DiagnosticText}" Foreground="#6E7681" FontSize="11" FontFamily="Consolas" />
    </Border>

  </Grid>

</DataTemplate>
