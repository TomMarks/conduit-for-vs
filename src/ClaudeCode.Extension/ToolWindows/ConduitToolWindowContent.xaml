<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml/styles"
              xmlns:colors="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml/colors">

  <!--
    Phase 0 placeholder. Phase 1 replaces this with a single Border hosting WebView2.
    Colors are inlined here ONLY for Phase 0; Phase 1 introduces ConduitBrushes.xaml
    generated from BRAND.md by tools/generate-xaml-tokens.ps1.
  -->

  <Border Background="#0E1116" Padding="16">
    <StackPanel VerticalAlignment="Top">

      <!-- Brand mark — signal waveform from BRAND.md icon B -->
      <Canvas Width="48" Height="48" Margin="0,0,0,12" HorizontalAlignment="Left">
        <Path Stroke="#2DD4BF" StrokeThickness="2.5"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
              Data="M 10,24 L 18,24 L 22,16 L 26,32 L 30,24 L 38,24" />
        <Ellipse Canvas.Left="35.5" Canvas.Top="21.5" Width="5" Height="5" Fill="#FB7185" />
      </Canvas>

      <TextBlock Text="Conduit" Foreground="#E6EDF3" FontSize="22" FontWeight="Medium" Margin="0,0,0,4" />
      <TextBlock Text="{Binding Tagline}" Foreground="#8B949E" FontSize="13" Margin="0,0,0,16" />
      <TextBlock Text="{Binding Greeting}" Foreground="#E6EDF3" FontSize="14" Margin="0,0,0,8" />
      <TextBlock Text="{Binding PhaseLabel}" Foreground="#6E7681" FontSize="12" />

    </StackPanel>
  </Border>

</DataTemplate>
